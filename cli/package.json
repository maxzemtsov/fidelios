{
  "name": "fidelios",
  "version": "0.0.1",
  "description": "FideliOS CLI \u2014 orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "fidelios": "./dist/index.js"
  },
  "keywords": [
    "fidelios",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxzemtsov/fidelios",
    "directory": "cli"
  },
  "homepage": "https://github.com/maxzemtsov/fidelios",
  "bugs": {
    "url": "https://github.com/maxzemtsov/fidelios/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@fidelios/adapter-claude-local": "workspace:*",
    "@fidelios/adapter-codex-local": "workspace:*",
    "@fidelios/adapter-cursor-local": "workspace:*",
    "@fidelios/adapter-gemini-local": "workspace:*",
    "@fidelios/adapter-opencode-local": "workspace:*",
    "@fidelios/adapter-pi-local": "workspace:*",
    "@fidelios/adapter-openclaw-gateway": "workspace:*",
    "@fidelios/adapter-utils": "workspace:*",
    "@fidelios/db": "workspace:*",
    "@fidelios/server": "workspace:*",
    "@fidelios/shared": "workspace:*",
    "drizzle-orm": "0.38.4",
    "dotenv": "^17.0.1",
    "commander": "^13.1.0",
    "embedded-postgres": "^18.1.0-beta.16",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
